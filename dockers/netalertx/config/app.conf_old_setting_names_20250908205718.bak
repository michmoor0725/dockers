SMTP_FORCE_SSL=False
SMTP_FORCE_SSL__metadata="{\"function\": \"FORCE_SSL\", \"type\": {\"dataType\": \"boolean\", \"elements\": [{\"elementType\": \"input\", \"elementOptions\": [{\"type\": \"checkbox\"}], \"transformers\": []}]}, \"default_value\": false, \"options\": [], \"localized\": [\"name\", \"description\"], \"name\": [{\"language_code\": \"en_us\", \"string\": \"Force SSL\"}, {\"language_code\": \"es_es\", \"string\": \"Forzar SSL\"}], \"description\": [{\"language_code\": \"en_us\", \"string\": \"Force SSL when connecting to your SMTP server.\"}, {\"language_code\": \"es_es\", \"string\": \"Forzar SSL al conectarse a su servidor SMTP\"}]}"
