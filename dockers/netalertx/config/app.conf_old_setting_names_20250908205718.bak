NEWDEV_devLastConnection__metadata="{\"function\": \"devLastConnection\", \"type\": {\"dataType\": \"string\", \"elements\": [{\"elementType\": \"input\", \"elementOptions\": [{\"readonly\": \"true\"}], \"transformers\": []}]}, \"format\": \"date-time\", \"default_value\": \"\", \"options\": [], \"localized\": [\"name\", \"description\"], \"name\": [{\"language_code\": \"en_us\", \"string\": \"Last Seen\"}], \"description\": [{\"language_code\": \"en_us\", \"string\": \"The date and time of the last seen connection with the device. Uneditable - Autodetected.\"}]}"
